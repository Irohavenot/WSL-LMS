<%= render "shared/navbar" %>

<div class="min-h-screen bg-gray-50 py-10">
  <div class="mx-auto max-w-7xl px-4">

    <div class="mb-6 flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Payments</h1>
        <p class="mt-1 text-sm text-gray-500">
          Monthly collection sheet •
          <span class="font-semibold text-green-600">Green</span>=complete,
          <span class="font-semibold text-orange-600">Orange</span>=deficient,
          <span class="font-semibold text-red-600">Red</span>=none
          <span class="mx-2">•</span>
          <span class="text-gray-400">Double-click a cell to edit</span>
        </p>
      </div>
    </div>

    <!-- Filters -->
    <div class="mb-6 rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
      <%= form_with url: dashboard_payments_path, method: :get, local: true, class: "grid grid-cols-1 md:grid-cols-4 gap-3 items-end" do %>
        <div>
          <label class="block text-xs font-medium uppercase tracking-wide text-gray-500 mb-1">Month</label>
          <%= month_field_tag :month, @month,
            class: "w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-200" %>
        </div>

        <div>
          <label class="block text-xs font-medium uppercase tracking-wide text-gray-500 mb-1">Mode</label>
          <%= select_tag :mode,
            options_for_select([["Weekly (Sundays)", "weekly"], ["Daily (Mon–Sat weekly view)", "daily"]], @mode),
            class: "w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-200" %>
        </div>

        <% if @mode == "daily" %>
          <%= hidden_field_tag :week_start, @week_start %>
          <div class="md:col-span-2 flex gap-2">
            <%= link_to "← Prev Week",
              dashboard_payments_path(month: @month, mode: "daily", week_start: (@week_start - 7.days).to_s),
              class: "w-full text-center rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition" %>
            <%= link_to "Next Week →",
              dashboard_payments_path(month: @month, mode: "daily", week_start: (@week_start + 7.days).to_s),
              class: "w-full text-center rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition" %>
          </div>
        <% else %>
          <div class="md:col-span-2 flex gap-2">
            <%= submit_tag "Apply",
              class: "w-full rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition" %>
            <%= link_to "Reset",
              dashboard_payments_path,
              class: "w-full text-center rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition" %>
          </div>
        <% end %>

        <% if @mode == "daily" %>
          <div class="md:col-span-4 flex gap-2">
            <%= submit_tag "Apply",
              class: "w-full rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition" %>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- Table -->
    <div class="rounded-2xl border border-gray-200 bg-white shadow-sm overflow-hidden">
      <div class="border-b border-gray-100 bg-gray-50 px-6 py-4 flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-gray-800">Collection Sheet</h2>
          <p class="text-xs text-gray-400">
            <%= @mode == "daily" ? "Daily view (Mon–Sat) • Week of #{@week_start.strftime("%b %d")}" : "Weekly view (Sundays)" %>
          </p>
        </div>
        <div class="text-xs text-gray-400 italic">
          Double-click any cell to record or edit a payment
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full text-sm border-collapse">
          <thead class="bg-gray-50 text-gray-500">
            <tr>
              <th class="sticky left-0 z-10 bg-gray-50 px-6 py-3 text-left font-semibold border-b border-r border-gray-200">Borrower</th>
              <% @dates.each do |d| %>
                <th class="px-4 py-3 text-center font-semibold whitespace-nowrap border-b border-r border-gray-100 min-w-[100px]">
                  <div class="text-gray-700"><%= d.strftime("%b %d") %></div>
                  <div class="text-[11px] text-gray-400"><%= d.strftime("%a") %></div>
                </th>
              <% end %>
            </tr>
          </thead>

          <tbody class="divide-y divide-gray-100">
            <% @loans.each do |loan| %>
              <% customer = loan.customer %>
              <tr class="hover:bg-gray-50/40 transition">
                <td class="sticky left-0 z-10 bg-white px-6 py-3 border-r border-gray-200">
                  <div class="font-semibold text-gray-900">
                    <%= link_to "#{customer.last_name}, #{customer.first_name}", loan_path(loan), class: "hover:underline" %>
                  </div>
                  <div class="text-xs text-gray-400">
                    Loan #<%= loan.id %> • PPS ₱<%= number_with_precision(loan.pay_per_session, precision: 2, delimiter: ",") %>
                  </div>
                </td>

                <% @dates.each do |date| %>
                  <% from = date.beginning_of_day %>
                  <% to   = date.end_of_day %>
                  <% day_payments = loan.payments.select { |p| p.paid_at && p.paid_at >= from && p.paid_at <= to } %>
                  <% paid = day_payments.sum { |p| p.amount_paid.to_d } %>
                  <% expected = loan.pay_per_session.to_d %>
                  <% already_paid = day_payments.any? %>

                  <%
                    bg_class =
                      if paid <= 0
                        "bg-red-50"
                      elsif paid < expected
                        "bg-orange-50"
                      else
                        "bg-green-50"
                      end

                    border_color =
                      if paid <= 0
                        "border-red-100"
                      elsif paid < expected
                        "border-orange-100"
                      else
                        "border-green-100"
                      end

                    text_color =
                      if paid <= 0
                        "text-red-400"
                      elsif paid < expected
                        "text-orange-600"
                      else
                        "text-green-700"
                      end
                  %>

                  <td
                    class="payment-cell relative px-0 py-0 text-center <%= bg_class %> border-r <%= border_color %> cursor-pointer select-none"
                    data-loan-id="<%= loan.id %>"
                    data-date="<%= date.to_time.change(hour: 12) %>"
                    data-expected="<%= expected %>"
                    data-paid="<%= paid %>"
                    data-already-paid="<%= already_paid %>"
                    data-record-url="<%= dashboard_record_payment_path %>"
                    title="<%= already_paid ? 'Payment recorded — double-click to edit' : 'No payment — double-click to add' %>"
                  >
                    <!-- Static display (shown by default) -->
                    <div class="cell-display flex flex-col items-center justify-center h-full py-3 px-2">
                      <span class="text-sm font-bold <%= text_color %>">
                        ₱<%= number_with_precision(paid, precision: 2, delimiter: ",") %>
                      </span>
                      <% if already_paid %>
                        <span class="text-[10px] mt-0.5 <%= text_color %> opacity-70">paid</span>
                      <% else %>
                        <span class="text-[10px] mt-0.5 text-gray-300">—</span>
                      <% end %>
                    </div>

                    <!-- Edit form (hidden by default, shown on double-click after auth) -->
                    <div class="cell-edit hidden absolute inset-0 z-20 flex items-center justify-center bg-white/95 border-2 border-blue-400 shadow-lg rounded-sm">
                      <%= form_with url: dashboard_record_payment_path, method: :post, local: true,
                        class: "cell-form flex flex-col items-center gap-1 p-2 w-full" do %>
                        <%= hidden_field_tag :loan_id, loan.id %>
                        <%= hidden_field_tag :paid_at, date.to_time.change(hour: 12) %>
                        <%= hidden_field_tag :password, "", class: "pw-field" %>

                        <% if already_paid %>
                          <div class="text-[9px] font-semibold text-orange-500 uppercase tracking-wide mb-0.5">Editing existing</div>
                        <% end %>

                        <%= number_field_tag :amount_paid,
                          (paid > 0 ? number_with_precision(paid, precision: 2) : nil),
                          step: 0.01, min: 0,
                          placeholder: "₱ amount",
                          autofocus: true,
                          class: "amount-input w-24 rounded border border-gray-300 px-2 py-1 text-xs text-center focus:outline-none focus:ring-2 focus:ring-blue-300" %>

                        <div class="flex gap-1 mt-1">
                          <button type="submit" class="rounded bg-gray-900 px-2 py-0.5 text-[10px] font-bold text-white hover:bg-black transition">Save</button>
                          <button type="button" class="cancel-btn rounded border border-gray-200 px-2 py-0.5 text-[10px] text-gray-500 hover:bg-gray-100 transition">Cancel</button>
                        </div>
                      <% end %>
                    </div>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @loans.empty? %>
        <div class="p-10 text-center text-gray-500">
          No active/overdue loans found.
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
(function () {
  const SESSION_KEY = "payments_auth_verified";

  // Check if already authenticated this session
  function isAuthenticated() {
    return sessionStorage.getItem(SESSION_KEY) === "true";
  }

  function setAuthenticated(pw) {
    sessionStorage.setItem(SESSION_KEY, "true");
    // Store pw temporarily in memory (not sessionStorage) for form injection
    window.__paymentsSessionPw = pw;
  }

  // Prompt for password once, verify via a lightweight fetch, then unlock
  async function authenticate() {
    return new Promise((resolve) => {
      const pw = prompt("Enter your password to edit payments on this page.\nYou won't be asked again until you leave.");
      if (!pw) { resolve(false); return; }

      // We verify by attempting a POST to a lightweight verify endpoint.
      // If you don't have one, we'll let the server reject on save instead
      // and just store the pw for form use.
      setAuthenticated(pw);
      resolve(true);
    });
  }

  // Clear auth when leaving the page
  window.addEventListener("beforeunload", () => {
    sessionStorage.removeItem(SESSION_KEY);
    window.__paymentsSessionPw = null;
  });

  // Wire up all payment cells
  document.querySelectorAll(".payment-cell").forEach((cell) => {
    const display = cell.querySelector(".cell-display");
    const editBox  = cell.querySelector(".cell-edit");
    const form     = cell.querySelector(".cell-form");
    const cancelBtn = cell.querySelector(".cancel-btn");
    const amountInput = cell.querySelector(".amount-input");
    const alreadyPaid = cell.dataset.alreadyPaid === "true";

    function openEdit() {
      editBox.classList.remove("hidden");
      display.classList.add("invisible");
      if (amountInput) {
        amountInput.focus();
        amountInput.select();
      }
    }

    function closeEdit() {
      editBox.classList.add("hidden");
      display.classList.remove("invisible");
    }

    // Double-click handler
    cell.addEventListener("dblclick", async (e) => {
      // Prevent double-click from triggering on the form itself
      if (e.target.closest(".cell-edit")) return;

      // If already paid, warn but still allow editing
      if (alreadyPaid) {
        const confirmEdit = confirm(
          "A payment has already been recorded for this session.\n\nDo you want to edit it?\n(Only one payment is allowed per session — this will overwrite the existing record.)"
        );
        if (!confirmEdit) return;
      }

      if (!isAuthenticated()) {
        const ok = await authenticate();
        if (!ok) return;
      }

      // Inject the stored password into the hidden field
      const pwField = form.querySelector(".pw-field");
      if (pwField && window.__paymentsSessionPw) {
        pwField.value = window.__paymentsSessionPw;
      }

      openEdit();
    });

    // Cancel button
    if (cancelBtn) {
      cancelBtn.addEventListener("click", (e) => {
        e.preventDefault();
        closeEdit();
      });
    }

    // Close on Escape key
    if (editBox) {
      editBox.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeEdit();
      });
    }

    // Also inject pw on form submit (in case it was cleared)
    if (form) {
      form.addEventListener("submit", (e) => {
        const pwField = form.querySelector(".pw-field");
        if (pwField && window.__paymentsSessionPw) {
          pwField.value = window.__paymentsSessionPw;
        }
        // Basic client-side guard: don't submit if amount is empty
        const amt = form.querySelector(".amount-input");
        if (!amt || !amt.value || parseFloat(amt.value) < 0) {
          e.preventDefault();
          amt.focus();
          amt.classList.add("ring-2", "ring-red-400");
        }
      });
    }
  });

  // Close any open cell editor when clicking outside
  document.addEventListener("click", (e) => {
    if (!e.target.closest(".payment-cell")) {
      document.querySelectorAll(".cell-edit").forEach(el => {
        if (!el.classList.contains("hidden")) {
          el.classList.add("hidden");
          el.closest(".payment-cell")?.querySelector(".cell-display")?.classList.remove("invisible");
        }
      });
    }
  });
})();
</script>
