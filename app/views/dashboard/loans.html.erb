<%# app/views/dashboard/loans.html.erb %>
<%= render 'shared/navbar' %>

<div class="min-h-screen bg-gray-50">
  <div class="mx-auto max-w-7xl px-4 py-10">

    <%# ── Page Header ── %>
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Loan Management</h1>
        <p class="mt-1 text-sm text-gray-500">All loans across every customer</p>
      </div>
    </div>

    <%# ── Summary Cards ── %>
    <%
      all_loans       = @loans
      active_loans    = all_loans.select { |l| l.status == "active" }
      overdue_loans   = all_loans.select { |l| l.status == "overdue" }
      completed_loans = all_loans.select { |l| %w[completed completed_late].include?(l.status) }
      total_remaining = all_loans.sum { |l| l.remaining_balance.to_f }
    %>
    <div class="mb-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
      <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Total Loans</p>
        <p class="mt-2 text-3xl font-bold text-gray-900"><%= all_loans.size %></p>
      </div>
      <div class="rounded-2xl border border-blue-100 bg-blue-50 p-5 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-widest text-blue-400">Active</p>
        <p class="mt-2 text-3xl font-bold text-blue-700"><%= active_loans.size %></p>
      </div>
      <div class="rounded-2xl border border-red-100 bg-red-50 p-5 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-widest text-red-400">Overdue</p>
        <p class="mt-2 text-3xl font-bold text-red-700"><%= overdue_loans.size %></p>
      </div>
      <div class="rounded-2xl border border-green-100 bg-green-50 p-5 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-widest text-green-400">Completed</p>
        <p class="mt-2 text-3xl font-bold text-green-700"><%= completed_loans.size %></p>
      </div>
    </div>

    <%# Total remaining balance banner %>
    <div class="mb-8 flex items-center justify-between rounded-2xl border border-gray-200 bg-white px-6 py-4 shadow-sm">
      <p class="text-sm font-medium text-gray-500">Total Outstanding Balance</p>
      <p class="text-2xl font-bold text-gray-900">₱<%= number_with_precision(total_remaining, precision: 2, delimiter: ",") %></p>
    </div>

    <%# ── Filter Tabs ── %>
    <div class="mb-6 flex items-center gap-1 rounded-xl border border-gray-200 bg-white p-1 shadow-sm w-fit">
      <% [
        ["all",            "All",            all_loans.size,       "gray"],
        ["active",         "Active",         active_loans.size,    "blue"],
        ["overdue",        "Overdue",        overdue_loans.size,   "red"],
        ["completed",      "Completed",      completed_loans.size, "green"],
      ].each do |filter, label, count, color| %>
        <button type="button"
                data-filter="<%= filter %>"
                onclick="filterLoans(this)"
                class="filter-tab flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold transition
                       <%= filter == 'all' ? 'bg-gray-900 text-white shadow-sm' : 'text-gray-500 hover:text-gray-700' %>">
          <%= label %>
          <span class="rounded-full px-1.5 py-0.5 text-[10px] font-bold
                       <%= filter == 'all' ? 'bg-white/20 text-white' : 'bg-gray-100 text-gray-500' %>">
            <%= count %>
          </span>
        </button>
      <% end %>
    </div>

    <%# ── Loans Table ── %>
    <% if @loans.empty? %>
      <div class="rounded-2xl border border-gray-200 bg-white p-16 text-center shadow-sm">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-gray-100">
          <svg class="h-8 w-8 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75"/>
          </svg>
        </div>
        <h2 class="mt-4 text-lg font-semibold text-gray-600">No loans yet</h2>
        <p class="mt-1 text-sm text-gray-400">Loans will appear here once added to a customer.</p>
      </div>

    <% else %>
      <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100 bg-gray-50 text-left text-xs font-semibold uppercase tracking-widest text-gray-400">
                <th class="px-5 py-3.5">Customer</th>
                <th class="px-5 py-3.5">Loan Amount</th>
                <th class="px-5 py-3.5">Total Balance</th>
                <th class="px-5 py-3.5">Remaining</th>
                <th class="px-5 py-3.5">Pay / Session</th>
                <th class="px-5 py-3.5">Maturity Date</th>
                <th class="px-5 py-3.5">Issued By</th>
                <th class="px-5 py-3.5">Status</th>
                <th class="px-5 py-3.5"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50" id="loans-table-body">
              <% @loans.each do |loan| %>
                <%
                  sc = {
                    "active"         => { bg: "bg-blue-100",   text: "text-blue-700",   dot: "bg-blue-500" },
                    "overdue"        => { bg: "bg-red-100",    text: "text-red-700",    dot: "bg-red-500" },
                    "completed"      => { bg: "bg-green-100",  text: "text-green-700",  dot: "bg-green-500" },
                    "completed_late" => { bg: "bg-yellow-100", text: "text-yellow-700", dot: "bg-yellow-500" },
                  }[loan.status] || { bg: "bg-gray-100", text: "text-gray-600", dot: "bg-gray-400" }
                %>
                <tr class="loan-row transition hover:bg-gray-50/60"
                    data-status="<%= loan.status %>">
                  <td class="px-5 py-4">
                    <div>
                      <p class="font-semibold text-gray-900">
                        <%= loan.customer.last_name %>, <%= loan.customer.first_name %>
                      </p>
                      <p class="text-xs text-gray-400">Loan #<%= loan.id %> · <%= loan.session_type.capitalize %></p>
                    </div>
                  </td>
                  <td class="px-5 py-4 font-medium text-gray-800">
                    ₱<%= number_with_precision(loan.loan_amount, precision: 2, delimiter: ",") %>
                  </td>
                  <td class="px-5 py-4 font-medium text-gray-800">
                    ₱<%= number_with_precision(loan.total_balance, precision: 2, delimiter: ",") %>
                  </td>
                  <td class="px-5 py-4">
                    <span class="font-semibold <%= loan.remaining_balance.to_f <= 0 ? 'text-green-600' : 'text-gray-800' %>">
                      ₱<%= number_with_precision(loan.remaining_balance, precision: 2, delimiter: ",") %>
                    </span>
                  </td>
                  <td class="px-5 py-4 text-gray-700">
                    ₱<%= number_with_precision(loan.pay_per_session, precision: 2, delimiter: ",") %>
                  </td>
                  <td class="px-5 py-4 <%= loan.overdue? ? 'text-red-600 font-semibold' : 'text-gray-700' %>">
                    <%= loan.maturity_date&.strftime("%b %d, %Y") || "—" %>
                  </td>
                  <td class="px-5 py-4 text-gray-700">
                    <%= loan.issued_by ? "#{loan.issued_by.last_name}, #{loan.issued_by.first_name[0]}." : "—" %>
                  </td>
                  <td class="px-5 py-4">
                    <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-semibold <%= sc[:bg] %> <%= sc[:text] %>">
                      <span class="h-1.5 w-1.5 rounded-full <%= sc[:dot] %>"></span>
                      <%= loan.display_status %>
                    </span>
                  </td>
                  <td class="px-5 py-4">
                    <div class="flex items-center gap-2">
                      <%= link_to "View", loan_path(loan),
                          class: "rounded-lg border border-gray-200 px-3 py-1.5 text-xs font-semibold text-gray-600 hover:bg-gray-50 transition whitespace-nowrap" %>
                      <%= link_to "Edit", edit_loan_path(loan),
                          class: "rounded-lg border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-semibold text-blue-700 hover:bg-blue-100 transition" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <%# Table footer count %>
        <div class="border-t border-gray-100 bg-gray-50 px-5 py-3">
          <p id="loans-count" class="text-xs text-gray-400">
            Showing <span class="font-semibold text-gray-600"><%= @loans.size %></span> loan<%= @loans.size == 1 ? "" : "s" %>
          </p>
        </div>
      </div>
    <% end %>

  </div>
</div>

<%# ── Filter JS ── %>
<script>
  const allRows    = () => document.querySelectorAll('.loan-row');
  const allTabs    = () => document.querySelectorAll('.filter-tab');
  const countEl    = () => document.getElementById('loans-count');

  // Status values that count as "completed" filter
  const completedStatuses = new Set(['completed', 'completed_late']);

  function filterLoans(tab) {
    const filter = tab.dataset.filter;

    // Update tab styles
    allTabs().forEach(t => {
      const active = t === tab;
      t.classList.toggle('bg-gray-900', active);
      t.classList.toggle('text-white',  active);
      t.classList.toggle('shadow-sm',   active);
      t.classList.toggle('text-gray-500', !active);
      t.classList.toggle('hover:text-gray-700', !active);
      // badge color
      const badge = t.querySelector('span');
      badge.classList.toggle('bg-white/20', active);
      badge.classList.toggle('text-white',  active);
      badge.classList.toggle('bg-gray-100', !active);
      badge.classList.toggle('text-gray-500', !active);
    });

    let visible = 0;
    allRows().forEach(row => {
      const status = row.dataset.status;
      const show = filter === 'all'
        || (filter === 'completed' ? completedStatuses.has(status) : status === filter);
      row.classList.toggle('hidden', !show);
      if (show) visible++;
    });

    if (countEl()) {
      countEl().innerHTML = `Showing <span class="font-semibold text-gray-600">${visible}</span> loan${visible === 1 ? '' : 's'}`;
    }
  }
</script>
