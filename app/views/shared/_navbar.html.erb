<nav class="bg-blue-600 text-white shadow-lg">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex justify-between items-center h-16">
      <!-- Logo/Brand -->
      <div class="flex items-center">
        <%= link_to "Lending MS", dashboard_path, class: "text-2xl font-bold" %>
      </div>
      
      <!-- Navigation Links -->
      <div class="hidden md:flex space-x-1">
        <%= link_to dashboard_path, class: "px-4 py-2 rounded-lg hover:bg-blue-700 transition #{current_page?(dashboard_path) ? 'bg-blue-700' : ''}" do %>
          <span class="flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
            Dashboard
          </span>
        <% end %>
        
        <%= link_to dashboard_customers_path, class: "px-4 py-2 rounded-lg hover:bg-blue-700 transition #{current_page?(dashboard_customers_path) ? 'bg-blue-700' : ''}" do %>
          <span class="flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
            Customers
          </span>
        <% end %>
        
        <%= link_to dashboard_loans_path, class: "px-4 py-2 rounded-lg hover:bg-blue-700 transition #{current_page?(dashboard_loans_path) ? 'bg-blue-700' : ''}" do %>
          <span class="flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Loans
          </span>
        <% end %>

        <%= link_to dashboard_payments_path,
          class: "px-4 py-2 rounded-lg hover:bg-blue-700 transition #{current_page?(dashboard_payments_path) ? 'bg-blue-700' : ''}" do %>
          <span class="flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 12h6m-6 4h6M7 4h10a2 2 0 012 2v12a2 2 0 01-2 2H7a2 2 0 01-2-2V6a2 2 0 012-2z" />
            </svg>
            Payments
          </span>
        <% end %>
        
        <%= link_to dashboard_records_path, class: "px-4 py-2 rounded-lg hover:bg-blue-700 transition #{current_page?(dashboard_records_path) ? 'bg-blue-700' : ''}" do %>
          <span class="flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            Records
          </span>
        <% end %>
        
        <%= link_to dashboard_reports_path, class: "px-4 py-2 rounded-lg hover:bg-blue-700 transition #{current_page?(dashboard_reports_path) ? 'bg-blue-700' : ''}" do %>
          <span class="flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
            Reports
          </span>
        <% end %>
      </div>

      <% if current_user %>
        <div class="hidden md:flex flex-col items-end text-right mr-4">
          <span class="text-sm font-semibold">
            <%= current_user.full_name %>
          </span>
          <span class="text-xs text-blue-100">
            <%= current_user.email %>
          </span>
        </div>
      <% end %>

      <div class="flex items-center">
        <%= button_to "Logout", logout_path, method: :delete,
            class: "px-4 py-2 bg-red-500 hover:bg-red-600 rounded-lg transition font-semibold" %>
      </div>
    </div>
    
    <!-- Mobile menu button -->
    <div class="md:hidden pb-4">
      <button id="mobile-menu-button" class="text-white hover:bg-blue-700 px-3 py-2 rounded">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>
  
  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden pb-4 px-4 space-y-2">
    <%= link_to "Dashboard", dashboard_path, class: "block px-4 py-2 rounded-lg hover:bg-blue-700 #{current_page?(dashboard_path) ? 'bg-blue-700' : ''}" %>
    <%= link_to "Customers", dashboard_customers_path, class: "block px-4 py-2 rounded-lg hover:bg-blue-700 #{current_page?(dashboard_customers_path) ? 'bg-blue-700' : ''}" %>
    <%= link_to "Loans", dashboard_loans_path, class: "block px-4 py-2 rounded-lg hover:bg-blue-700 #{current_page?(dashboard_loans_path) ? 'bg-blue-700' : ''}" %>
    <%= link_to "Records", dashboard_records_path, class: "block px-4 py-2 rounded-lg hover:bg-blue-700 #{current_page?(dashboard_records_path) ? 'bg-blue-700' : ''}" %>
    <%= link_to "Reports", dashboard_reports_path, class: "block px-4 py-2 rounded-lg hover:bg-blue-700 #{current_page?(dashboard_reports_path) ? 'bg-blue-700' : ''}" %>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    
    if (button && menu) {
      button.addEventListener('click', function() {
        menu.classList.toggle('hidden');
      });
    }
  });
</script>