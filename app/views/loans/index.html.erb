<%# app/views/loans/index.html.erb %>
<%= render 'shared/navbar' %>

<div class="min-h-screen bg-gray-50 py-10">
  <div class="mx-auto max-w-5xl px-4">

    <%# Header %>
    <div class="mb-6 flex items-center justify-between">
      <div>
        <nav class="mb-1 flex items-center gap-2 text-sm text-gray-400">
          <%= link_to "Customers", customers_path, class: "hover:text-gray-600 transition" %>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          <%= link_to @customer.last_name + ", " + @customer.first_name, @customer, class: "hover:text-gray-600 transition" %>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          <span class="text-gray-600 font-medium">Loans</span>
        </nav>
        <h1 class="text-2xl font-bold text-gray-900">
          Loans — <%= @customer.last_name %>, <%= @customer.first_name %>
        </h1>
      </div>
      <%= link_to "＋ Add Loan", new_customer_loan_path(@customer),
          class: "inline-flex items-center rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 transition" %>
    </div>

    <%# Flash %>
    <% if notice %>
      <div class="mb-4 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm font-medium text-green-700">
        <%= notice %>
      </div>
    <% end %>

    <%# Empty state %>
    <% if @loans.empty? %>
      <div class="rounded-2xl border border-gray-200 bg-white p-12 text-center shadow-sm">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-blue-50">
          <svg class="h-8 w-8 text-blue-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h2 class="mt-4 text-lg font-semibold text-gray-700">No loans yet</h2>
        <p class="mt-1 text-sm text-gray-400">Add the first loan for this customer.</p>
        <%= link_to "Add Loan", new_customer_loan_path(@customer),
            class: "mt-4 inline-flex items-center rounded-lg bg-blue-600 px-5 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition" %>
      </div>

    <%# Loan cards %>
    <% else %>
      <div class="space-y-4">
        <% @loans.each do |loan| %>
          <%
            status_colors = {
              "active"         => { bg: "bg-blue-100",   text: "text-blue-700",   dot: "bg-blue-500" },
              "overdue"        => { bg: "bg-red-100",    text: "text-red-700",    dot: "bg-red-500" },
              "completed"      => { bg: "bg-green-100",  text: "text-green-700",  dot: "bg-green-500" },
              "completed_late" => { bg: "bg-yellow-100", text: "text-yellow-700", dot: "bg-yellow-500" },
            }
            sc = status_colors[loan.status] || { bg: "bg-gray-100", text: "text-gray-700", dot: "bg-gray-400" }
          %>
          <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:shadow-md">
            <div class="flex items-start justify-between gap-4">
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-900">Loan #<%= loan.id %></p>
                  <p class="text-xs text-gray-400">Added <%= loan.date_added.strftime("%b %d, %Y") %></p>
                </div>
              </div>
              <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-semibold <%= sc[:bg] %> <%= sc[:text] %>">
                <span class="h-1.5 w-1.5 rounded-full <%= sc[:dot] %>"></span>
                <%= loan.display_status %>
              </span>
            </div>

            <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
              <div>
                <p class="text-[11px] uppercase tracking-wide text-gray-400">Loan Amount</p>
                <p class="mt-0.5 font-semibold text-gray-800">₱<%= number_with_precision(loan.loan_amount, precision: 2, delimiter: ",") %></p>
              </div>
              <div>
                <p class="text-[11px] uppercase tracking-wide text-gray-400">Total Balance</p>
                <p class="mt-0.5 font-semibold text-gray-800">₱<%= number_with_precision(loan.total_balance, precision: 2, delimiter: ",") %></p>
              </div>
              <div>
                <p class="text-[11px] uppercase tracking-wide text-gray-400">Remaining</p>
                <p class="mt-0.5 font-semibold <%= loan.remaining_balance.to_f > 0 ? 'text-gray-800' : 'text-green-600' %>">
                  ₱<%= number_with_precision(loan.remaining_balance, precision: 2, delimiter: ",") %>
                </p>
              </div>
              <div>
                <p class="text-[11px] uppercase tracking-wide text-gray-400">Maturity Date</p>
                <p class="mt-0.5 font-semibold <%= loan.overdue? ? 'text-red-600' : 'text-gray-800' %>">
                  <%= loan.maturity_date&.strftime("%b %d, %Y") || "—" %>
                </p>
              </div>
              <div>
                <p class="text-[11px] uppercase tracking-wide text-gray-400">Pay / Session</p>
                <p class="mt-0.5 font-semibold text-gray-800">₱<%= number_with_precision(loan.pay_per_session, precision: 2, delimiter: ",") %></p>
              </div>
              <div>
                <p class="text-[11px] uppercase tracking-wide text-gray-400">Sessions</p>
                <p class="mt-0.5 font-semibold text-gray-800"><%= loan.total_sessions %> (<%= loan.session_type.capitalize %>)</p>
              </div>
              <div>
                <p class="text-[11px] uppercase tracking-wide text-gray-400">Issued By</p>
                <p class="mt-0.5 font-semibold text-gray-800 truncate"><%= loan.issued_by&.last_name || "—" %></p>
              </div>
              <div>
                <p class="text-[11px] uppercase tracking-wide text-gray-400">Date Issued</p>
                <p class="mt-0.5 font-semibold text-gray-800"><%= loan.date_issued&.strftime("%b %d, %Y") || "—" %></p>
              </div>
            </div>

            <div class="mt-4 flex items-center justify-end gap-2 border-t border-gray-50 pt-3">
              <%= link_to "View", loan_path(loan),
                  class: "rounded-lg border border-gray-200 bg-white px-4 py-1.5 text-xs font-semibold text-gray-600 hover:bg-gray-50 transition" %>
              <%= link_to "Edit", edit_loan_path(loan),
                  class: "rounded-lg border border-blue-200 bg-blue-50 px-4 py-1.5 text-xs font-semibold text-blue-700 hover:bg-blue-100 transition" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

  </div>
</div>
