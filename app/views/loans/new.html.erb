<%# app/views/loans/new.html.erb %>
<%= render 'shared/navbar' %>

<div class="min-h-screen bg-gray-50 py-10">
  <div class="mx-auto max-w-2xl px-4">
    <%# Breadcrumb %>
    <nav class="mb-6 flex items-center gap-2 text-sm text-gray-400">
      <%= link_to "Customers", customers_path, class: "hover:text-gray-600 transition" %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <%= link_to @customer.last_name + ", " + @customer.first_name, @customer, class: "hover:text-gray-600 transition" %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-600 font-medium">New Loan</span>
    </nav>

    <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
      <div class="mb-8">
        <h1 class="text-xl font-bold text-gray-900">Add New Loan</h1>
        <p class="mt-1 text-sm text-gray-500">
          For customer: <span class="font-medium text-gray-700"><%= @customer.last_name %>, <%= @customer.first_name %></span>
        </p>
      </div>

      <%= render 'form', loan: @loan %>
    </div>
  </div>
</div>
