<%# app/views/loans/show.html.erb %>
<%= render 'shared/navbar' %>

<div class="min-h-screen bg-gray-50 py-10">
  <div class="mx-auto max-w-3xl px-4">

    <nav class="mb-6 flex items-center gap-2 text-sm text-gray-400">
      <%= link_to "Customers", customers_path, class: "hover:text-gray-600 transition" %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <%= link_to @customer.last_name + ", " + @customer.first_name, @customer, class: "hover:text-gray-600 transition" %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <%= link_to "Loans", customer_loans_path(@customer), class: "hover:text-gray-600 transition" %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-600 font-medium">Loan #<%= @loan.id %></span>
    </nav>

    <%
      sc = {
        "active"         => { bg: "bg-blue-100",   text: "text-blue-700",   dot: "bg-blue-500" },
        "overdue"        => { bg: "bg-red-100",    text: "text-red-700",    dot: "bg-red-500" },
        "completed"      => { bg: "bg-green-100",  text: "text-green-700",  dot: "bg-green-500" },
        "completed_late" => { bg: "bg-yellow-100", text: "text-yellow-700", dot: "bg-yellow-500" },
      }[@loan.status] || { bg: "bg-gray-100", text: "text-gray-700", dot: "bg-gray-400" }
    %>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-sm overflow-hidden">
      <%# Header bar %>
      <div class="flex items-center justify-between border-b border-gray-100 bg-gray-50 px-6 py-4">
        <div>
          <h1 class="text-lg font-bold text-gray-900">Loan #<%= @loan.id %></h1>
          <p class="text-xs text-gray-400">Added <%= @loan.date_added.strftime("%B %d, %Y %I:%M %p") %> by <%= @loan.added_by.last_name %></p>
        </div>
        <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-sm font-semibold <%= sc[:bg] %> <%= sc[:text] %>">
          <span class="h-2 w-2 rounded-full <%= sc[:dot] %>"></span>
          <%= @loan.display_status %>
        </span>
      </div>

      <div class="p-6 space-y-6">
        <%# Info grid %>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
          <% fields = [
            ["Loan Amount",      "₱#{number_with_precision(@loan.loan_amount, precision: 2, delimiter: ',')}"],
            ["Total Balance",    "₱#{number_with_precision(@loan.total_balance, precision: 2, delimiter: ',')}"],
            ["Remaining Balance","₱#{number_with_precision(@loan.remaining_balance, precision: 2, delimiter: ',')}"],
            ["Pay Per Session",  "₱#{number_with_precision(@loan.pay_per_session, precision: 2, delimiter: ',')}"],
            ["Total Sessions",   @loan.total_sessions.to_s],
            ["Session Type",     @loan.session_type.capitalize],
            ["Months to Pay",    @loan.total_months_to_pay.to_s],
            ["Interest Rate",    "#{(@loan.interest_rate * 100).round(2)}%"],
            ["Date Issued",      @loan.date_issued&.strftime("%B %d, %Y") || "—"],
            ["Maturity Date",    @loan.maturity_date&.strftime("%B %d, %Y") || "—"],
            ["Issued By",        @loan.issued_by ? "#{@loan.issued_by.last_name}, #{@loan.issued_by.first_name}" : "—"],
            ["Added By",         "#{@loan.added_by.last_name}, #{@loan.added_by.first_name}"],
          ] %>
          <% fields.each do |label, value| %>
            <div class="rounded-xl border border-gray-100 bg-gray-50 p-3">
              <p class="text-[11px] uppercase tracking-wide text-gray-400"><%= label %></p>
              <p class="mt-0.5 text-sm font-semibold text-gray-800"><%= value %></p>
            </div>
          <% end %>
        </div>

        <%# Images row %>
        <% if @loan.proof_of_issue.attached? || @loan.qr_image.attached? %>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <% if @loan.proof_of_issue.attached? %>
              <div>
                <p class="mb-2 text-xs font-medium uppercase tracking-wide text-gray-400">Proof of Issue</p>
                <%= image_tag url_for(@loan.proof_of_issue), class: "rounded-xl border border-gray-200 object-cover w-full max-h-52", alt: "Proof of issue" %>
              </div>
            <% end %>
            <% if @loan.qr_image.attached? %>
              <div>
                <p class="mb-2 text-xs font-medium uppercase tracking-wide text-gray-400">QR Code</p>
                <%= image_tag url_for(@loan.qr_image), class: "rounded-xl border border-gray-200 object-contain bg-white p-3 w-full max-h-52", alt: "QR code" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="flex items-center justify-end gap-3 border-t border-gray-100 bg-gray-50 px-6 py-4">
        <%= link_to "← Back to Loans", customer_loans_path(@customer),
            class: "rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-600 hover:bg-gray-50 transition" %>
        <%= link_to "Edit Loan", edit_loan_path(@loan),
            class: "rounded-lg bg-blue-600 px-5 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition" %>
        <%= link_to "View Payments", loan_payments_path(@loan),
        class: "rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition" %>

       <%= link_to "Add Payment", new_loan_payment_path(@loan),
        class: "rounded-lg bg-green-600 px-5 py-2 text-sm font-semibold text-white hover:bg-green-700 transition" %>
      </div>
    </div>

  </div>
</div>
