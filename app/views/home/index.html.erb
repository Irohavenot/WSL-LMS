<div class="min-h-screen flex items-center justify-center bg-gray-100">
  <div class="bg-white p-10 rounded-2xl shadow-lg text-center max-w-md w-full">
    <h1 class="text-4xl font-bold text-blue-600 mb-4">
      Lending Management System
    </h1>

    <% if logged_in? %>
      <p class="text-gray-600 text-lg mb-6">
        Welcome back, <%= current_user.email %>! 🎉
      </p>
      
      <%= button_to "Logout", logout_path, method: :delete, 
          class: "w-full px-6 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition" %>
    <% else %>
      <p class="text-gray-600 text-lg mb-6">
        Manage your lending operations efficiently 🚀
      </p>

      <div class="space-y-3">
        <%= link_to "Login", login_path, 
            class: "block w-full px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition" %>
        
        <%= link_to "Register", register_path, 
            class: "block w-full px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition" %>
      </div>
    <% end %>
  </div>
</div>