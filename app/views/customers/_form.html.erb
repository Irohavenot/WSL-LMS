
<%= form_with model: customer, class: "space-y-8" do |f| %>
  <%# ── Error Banner ── %>
  <% if customer.errors.any? %>
    <div class="flex gap-3 rounded-xl border border-red-200 bg-red-50 p-4">
      <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-500" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm-.75-5.75a.75.75 0 001.5 0V8a.75.75 0 00-1.5 0v4.25zm.75 2.75a.75.75 0 100-1.5.75.75 0 000 1.5z" clip-rule="evenodd"/>
      </svg>
      <div>
        <p class="text-sm font-semibold text-red-700">Please fix the following errors:</p>
        <ul class="mt-1 list-disc pl-4 text-sm text-red-600 space-y-0.5">
          <% customer.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <%# ── Section: Personal Information ── %>
  <fieldset class="space-y-5">
    <legend class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-gray-400">
      <span class="flex h-5 w-5 items-center justify-center rounded-full bg-blue-600 text-white text-[10px] font-bold">1</span>
      Personal Information
    </legend>

    <%# Name row %>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      <div class="space-y-1">
        <%= f.label :last_name, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :last_name,
            placeholder: "e.g. Dela Cruz",
            class: "block w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm shadow-sm
                    placeholder:text-gray-400
                    focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20
                    transition" %>
      </div>

      <div class="space-y-1">
        <%= f.label :first_name, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :first_name,
            placeholder: "e.g. Juan",
            class: "block w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm shadow-sm
                    placeholder:text-gray-400
                    focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20
                    transition" %>
      </div>

      <div class="space-y-1">
        <%= f.label :middle_initial, class: "block text-sm font-medium text-gray-700" %>
        <div class="relative">
          <%= f.text_field :middle_initial,
              maxlength: 1,
              placeholder: "A",
              class: "block w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm shadow-sm
                      placeholder:text-gray-400
                      focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20
                      transition" %>
          <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-xs text-gray-400">optional</span>
        </div>
      </div>
    </div>

    <%# DOB + Contact %>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div class="space-y-1">
        <%= f.label :date_of_birth, class: "block text-sm font-medium text-gray-700" %>
        <%= f.date_field :date_of_birth,
            class: "block w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm shadow-sm
                    focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20
                    transition" %>
      </div>

      <div class="space-y-1">
        <%= f.label :contact_number, class: "block text-sm font-medium text-gray-700" %>
        <div class="relative">
          <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-sm text-gray-400">📞</span>
          <%= f.text_field :contact_number,
              placeholder: "09XX XXX XXXX",
              class: "block w-full rounded-lg border border-gray-300 bg-white py-2.5 pl-9 pr-3 text-sm shadow-sm
                      placeholder:text-gray-400
                      focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20
                      transition" %>
        </div>
      </div>
    </div>

    <%# Address %>
    <div class="space-y-1">
      <%= f.label :address, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :address,
          rows: 3,
          placeholder: "House No., Street, Barangay, City/Municipality, Province",
          class: "block w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm shadow-sm
                  placeholder:text-gray-400 resize-none
                  focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20
                  transition" %>
    </div>
  </fieldset>

  <hr class="border-gray-100">

  <%# ── Section: Loan Details ── %>
  <fieldset class="space-y-5">
    <legend class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-gray-400">
      <span class="flex h-5 w-5 items-center justify-center rounded-full bg-blue-600 text-white text-[10px] font-bold">2</span>
      Loan Details
    </legend>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div class="space-y-1">
        <%= f.label :total_no_of_loans, class: "block text-sm font-medium text-gray-700" do %>
          Total No. of Loans
          <span class="ml-1 text-xs font-normal text-gray-400">(optional)</span>
        <% end %>
        <%= f.number_field :total_no_of_loans,
            min: 0,
            placeholder: "0",
            class: "block w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm shadow-sm
                    placeholder:text-gray-400
                    focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20
                    transition" %>
      </div>

      <div class="space-y-1">
        <%= f.label :co_maker, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :co_maker,
            placeholder: "Full name of co-maker",
            class: "block w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm shadow-sm
                    placeholder:text-gray-400
                    focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20
                    transition" %>
      </div>
    </div>

    <div class="space-y-1">
      <%= f.label :collateral, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :collateral,
          placeholder: "e.g. Land title, vehicle, jewelry",
          class: "block w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm shadow-sm
                  placeholder:text-gray-400
                  focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20
                  transition" %>
    </div>
  </fieldset>

  <hr class="border-gray-100">

  <%# ── Section: Government ID ── %>
  <fieldset class="space-y-5">
    <legend class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-gray-400">
      <span class="flex h-5 w-5 items-center justify-center rounded-full bg-blue-600 text-white text-[10px] font-bold">3</span>
      Government ID
    </legend>

    <div class="space-y-1">
      <%= f.label :id_submitted, class: "block text-sm font-medium text-gray-700" %>
      <div class="relative">
        <%= f.select :id_submitted,
            options_for_select(Customer::VALID_PH_IDS, customer.id_submitted),
            { prompt: "Select a valid ID type…" },
            class: "block w-full appearance-none rounded-lg border border-gray-300 bg-white px-3 py-2.5 pr-9 text-sm shadow-sm
                    focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20
                    transition" %>
        <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </span>
      </div>
    </div>

    <%# ID Image Upload %>
    <div class="space-y-2">
      <label class="block text-sm font-medium text-gray-700">
        ID Photo
        <span class="ml-1 text-xs font-normal text-gray-400">(front of ID)</span>
      </label>

      <%# Drop zone %>
      <div id="id-upload-area"
     data-existing-url="<%= customer.id_image.attached? ? url_for(customer.id_image) : "" %>"
     data-existing-filename="<%= customer.id_image.attached? ? customer.id_image.filename.to_s : "" %>"
     class="relative flex min-h-[200px] cursor-pointer flex-col items-center justify-center
            rounded-xl border-2 border-dashed border-gray-300 bg-gray-50
            transition hover:border-blue-400 hover:bg-blue-50"
     onclick="document.getElementById('id_image_input').click()">
        <%# Empty state icon + text %>
        <div id="upload-placeholder" class="flex flex-col items-center gap-2 text-center px-6 py-8">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white shadow-sm ring-1 ring-gray-200">
            <svg class="h-7 w-7 text-blue-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 22V12h6v10"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-700">Upload ID image</p>
            <p class="mt-0.5 text-xs text-gray-400">Click or drag & drop · JPG, PNG, WEBP · max 5 MB</p>
          </div>
          <span class="mt-1 inline-flex items-center rounded-full bg-blue-600 px-4 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-blue-700 transition">
            Choose File
          </span>
        </div>

        <%# Preview (hidden until file chosen) %>
        <div id="upload-preview" class="hidden w-full p-4">
          <%# ID card mock %>
          <div class="mx-auto max-w-sm">
            <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-slate-800 to-slate-900 shadow-2xl ring-1 ring-white/10">
              <%# card top bar %>
              <div class="flex items-center justify-between bg-blue-700 px-4 py-2">
                <div class="flex items-center gap-1.5">
                  <div class="h-2 w-2 rounded-full bg-white/60"></div>
                  <span class="text-[11px] font-semibold uppercase tracking-widest text-white/80">Government ID</span>
                </div>
                <svg class="h-4 w-4 text-white/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0"/>
                </svg>
              </div>

              <%# image area %>
              <div class="relative aspect-[16/9] w-full overflow-hidden">
                <img id="id-preview-img"
                     src=""
                     alt="ID preview"
                     class="h-full w-full object-cover object-center">
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              </div>

              <%# card footer %>
              <div class="flex items-center justify-between px-4 py-3">
                <div>
                  <p id="preview-filename" class="truncate text-xs font-medium text-white/90 max-w-[180px]">filename.jpg</p>
                  <p id="preview-filesize" class="text-[10px] text-white/40">0 KB</p>
                </div>
                <button type="button"
                        onclick="event.stopPropagation(); clearIdPreview()"
                        class="flex h-7 w-7 items-center justify-center rounded-full bg-white/10 text-white/70
                               hover:bg-red-500/80 hover:text-white transition"
                        title="Remove image">
                  <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                </button>
              </div>
            </div>

            <p class="mt-2 text-center text-[11px] text-gray-400">
              Click the card or
              <button type="button" onclick="event.stopPropagation(); document.getElementById('id_image_input').click()"
                      class="text-blue-600 underline underline-offset-2 hover:text-blue-700">choose a different file</button>
            </p>
          </div>
        </div>
      </div>

      <%# Actual hidden file input — use f.file_field for Rails param mapping %>
      <%= f.file_field :id_image,
          id: "id_image_input",
          accept: "image/jpeg,image/png,image/webp",
          class: "sr-only",
          onchange: "handleIdUpload(this)" %>
    </div>
  </fieldset>

  <%# ── Actions ── %>
  <div class="flex items-center justify-end gap-3 border-t border-gray-100 pt-6">
    <%= link_to "Cancel", customers_path,
        class: "rounded-lg border border-gray-200 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700
                shadow-sm hover:bg-gray-50 transition" %>
    <%= f.submit(@customer.persisted? ? "Update Customer" : "Add Customer",
      class: "cursor-pointer rounded-lg bg-blue-600 px-6 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 active:scale-95 transition") %>
  </div>
<% end %>

<%# ── ID Upload JS ── %>
<script>
  document.addEventListener('turbo:load', () => {
    const uploadArea = document.getElementById('id-upload-area');
    if (!uploadArea) return;

    // prevent duplicate bindings (important for Turbo)
    if (uploadArea.dataset.bound === "1") return;
    uploadArea.dataset.bound = "1";

    const placeholder = document.getElementById('upload-placeholder');
    const preview     = document.getElementById('upload-preview');
    const previewImg  = document.getElementById('id-preview-img');
    const input       = document.getElementById('id_image_input');

    // preload existing image (edit page)
    const existingUrl = uploadArea.dataset.existingUrl;
    const existingFilename = uploadArea.dataset.existingFilename;

    if (existingUrl) {
      previewImg.src = existingUrl;
      document.getElementById('preview-filename').textContent =
        existingFilename || "Current ID image";
      document.getElementById('preview-filesize').textContent = "Existing file";
      placeholder.classList.add('hidden');
      preview.classList.remove('hidden');
    }

    // Drag-and-drop
    uploadArea.addEventListener('dragover', e => {
      e.preventDefault();
      uploadArea.classList.add('border-blue-500', 'bg-blue-50');
    });

    uploadArea.addEventListener('dragleave', () => {
      uploadArea.classList.remove('border-blue-500', 'bg-blue-50');
    });

    uploadArea.addEventListener('drop', e => {
      e.preventDefault();
      uploadArea.classList.remove('border-blue-500', 'bg-blue-50');
      const file = e.dataTransfer.files[0];
      if (file && file.type.startsWith('image/')) {
        const dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
        renderPreview(file);
      }
    });

    // expose these so your inline onchange/onclick still work
    window.handleIdUpload = function(el) {
      if (el.files && el.files[0]) renderPreview(el.files[0]);
    };

    window.clearIdPreview = function() {
      input.value = '';
      previewImg.src = '';
      preview.classList.add('hidden');
      placeholder.classList.remove('hidden');
    };

    function renderPreview(file) {
      const reader = new FileReader();
      reader.onload = e => {
        previewImg.src = e.target.result;
        document.getElementById('preview-filename').textContent = file.name;
        document.getElementById('preview-filesize').textContent = formatBytes(file.size);
        placeholder.classList.add('hidden');
        preview.classList.remove('hidden');
      };
      reader.readAsDataURL(file);
    }

    function formatBytes(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / 1048576).toFixed(1) + ' MB';
    }
  });
</script>
