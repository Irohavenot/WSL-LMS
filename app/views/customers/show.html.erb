<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex items-start justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @customer.full_name %></h1>
      <p class="text-gray-600">Added by <%= @customer.added_by.full_name %></p>
    </div>

    <div class="flex gap-2">
      <%= link_to "Edit", edit_customer_path(@customer), class: "rounded-lg bg-gray-100 px-4 py-2 font-semibold text-gray-800 hover:bg-gray-200 transition" %>
      <%= link_to "Back", customers_path, class: "rounded-lg bg-gray-100 px-4 py-2 font-semibold text-gray-800 hover:bg-gray-200 transition" %>
    </div>
  </div>

  <div class="bg-white rounded-2xl shadow p-6 space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <div class="text-sm text-gray-500">Date of Birth</div>
        <div class="font-medium"><%= @customer.date_of_birth %></div>
      </div>
      <div>
        <div class="text-sm text-gray-500">Contact Number</div>
        <div class="font-medium"><%= @customer.contact_number %></div>
      </div>
    </div>

    <div>
      <div class="text-sm text-gray-500">Address</div>
      <div class="font-medium"><%= @customer.address %></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <div class="text-sm text-gray-500">ID Submitted</div>
        <div class="font-medium"><%= @customer.id_submitted %></div>
      </div>
      <div>
        <div class="text-sm text-gray-500">Total No. of Loans</div>
        <div class="font-medium"><%= @customer.total_no_of_loans || "—" %></div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <div class="text-sm text-gray-500">Co-maker</div>
        <div class="font-medium"><%= @customer.co_maker.presence || "—" %></div>
      </div>
      <div>
        <div class="text-sm text-gray-500">Collateral</div>
        <div class="font-medium"><%= @customer.collateral.presence || "—" %></div>
      </div>
    </div>
<div class="mt-6">
  <p class="text-sm font-semibold text-gray-600 mb-2">Uploaded ID:</p>

  <% if @customer.id_image.attached? %>
    <div class="rounded-2xl border border-gray-200 bg-gray-50 p-4">
      <%= image_tag @customer.id_image.variant(resize_to_limit: [900, 900]),
          class: "w-full max-w-md rounded-xl shadow" %>

      <div class="mt-3 flex items-center gap-2">
        <%= link_to "Open full image",
            url_for(@customer.id_image),
            target: "_blank",
            rel: "noopener",
            class: "text-sm font-semibold text-blue-600 hover:text-blue-700 underline underline-offset-2" %>

        <span class="text-xs text-gray-400">•</span>

        <span class="text-xs text-gray-500">
          <%= number_to_human_size(@customer.id_image.byte_size) %>
        </span>
      </div>
    </div>
  <% else %>
    <div class="flex items-center justify-center rounded-2xl border-2 border-dashed border-gray-300 bg-gray-50 p-10 text-center">
      <div>
        <div class="text-sm font-semibold text-gray-500">No ID uploaded</div>
        <div class="text-xs text-gray-400 mt-1">Customer has not submitted an ID image.</div>
      </div>
    </div>
  <% end %>
</div>
  </div>
</div>