<%# app/views/customers/show.html.erb %>
<%= render "shared/navbar" %>

<div class="max-w-4xl mx-auto px-4 py-8 space-y-6">

  <%# ── Header ── %>
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @customer.full_name %></h1>
      <p class="text-sm text-gray-500">Added by <%= @customer.added_by.full_name %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Edit", edit_customer_path(@customer),
          class: "rounded-lg bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-800 hover:bg-gray-200 transition" %>
      <%= link_to "Back", customers_path,
          class: "rounded-lg bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-800 hover:bg-gray-200 transition" %>
    </div>
  </div>

  <%# ── Customer Info Card ── %>
  <div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6 space-y-4">

    <h2 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-gray-400">
      <span class="flex h-5 w-5 items-center justify-center rounded-full bg-blue-600 text-white text-[10px] font-bold">1</span>
      Personal Information
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <div class="text-xs text-gray-400 uppercase tracking-wide">Date of Birth</div>
        <div class="font-medium text-gray-800"><%= @customer.date_of_birth&.strftime("%B %d, %Y") || "—" %></div>
      </div>
      <div>
        <div class="text-xs text-gray-400 uppercase tracking-wide">Contact Number</div>
        <div class="font-medium text-gray-800"><%= @customer.contact_number.presence || "—" %></div>
      </div>
    </div>

    <div>
      <div class="text-xs text-gray-400 uppercase tracking-wide">Address</div>
      <div class="font-medium text-gray-800"><%= @customer.address.presence || "—" %></div>
    </div>

    <hr class="border-gray-100">

    <h2 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-gray-400">
      <span class="flex h-5 w-5 items-center justify-center rounded-full bg-blue-600 text-white text-[10px] font-bold">2</span>
      Loan Details
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <div class="text-xs text-gray-400 uppercase tracking-wide">Total No. of Loans</div>
        <div class="font-medium text-gray-800"><%= @customer.total_no_of_loans || "—" %></div>
      </div>
      <div>
        <div class="text-xs text-gray-400 uppercase tracking-wide">ID Submitted</div>
        <div class="font-medium text-gray-800"><%= @customer.id_submitted.presence || "—" %></div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <div class="text-xs text-gray-400 uppercase tracking-wide">Co-maker</div>
        <div class="font-medium text-gray-800"><%= @customer.co_maker.presence || "—" %></div>
      </div>
      <div>
        <div class="text-xs text-gray-400 uppercase tracking-wide">Collateral</div>
        <div class="font-medium text-gray-800"><%= @customer.collateral.presence || "—" %></div>
      </div>
    </div>

    <hr class="border-gray-100">

    <h2 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-gray-400">
      <span class="flex h-5 w-5 items-center justify-center rounded-full bg-blue-600 text-white text-[10px] font-bold">3</span>
      Government ID
    </h2>

    <% if @customer.id_image.attached? %>
      <div class="rounded-xl border border-gray-200 bg-gray-50 p-4">
        <%= image_tag @customer.id_image.variant(resize_to_limit: [900, 900]),
            class: "w-full max-w-md rounded-xl shadow" %>
        <div class="mt-3 flex items-center gap-2">
          <%= link_to "Open full image", url_for(@customer.id_image),
              target: "_blank", rel: "noopener",
              class: "text-sm font-semibold text-blue-600 hover:text-blue-700 underline underline-offset-2" %>
          <span class="text-xs text-gray-400">•</span>
          <span class="text-xs text-gray-500"><%= number_to_human_size(@customer.id_image.byte_size) %></span>
        </div>
      </div>
    <% else %>
      <div class="flex items-center justify-center rounded-xl border-2 border-dashed border-gray-200 bg-gray-50 p-8 text-center">
        <div>
          <p class="text-sm font-semibold text-gray-500">No ID uploaded</p>
          <p class="text-xs text-gray-400 mt-1">Customer has not submitted an ID image.</p>
        </div>
      </div>
    <% end %>
  </div>

  <%# ── Loans Section ── %>
  <div>
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-lg font-bold text-gray-900">Loans</h2>
      <%= link_to "＋ Add Loan", new_customer_loan_path(@customer),
          class: "inline-flex items-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 transition" %>
    </div>

    <% loans = @customer.loans.includes(:issued_by).order(created_at: :desc) %>

    <% if loans.empty? %>
      <div class="flex flex-col items-center justify-center rounded-2xl border-2 border-dashed border-gray-200 bg-white p-12 text-center">
        <div class="flex h-14 w-14 items-center justify-center rounded-full bg-blue-50">
          <svg class="h-7 w-7 text-blue-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75"/>
          </svg>
        </div>
        <p class="mt-3 text-sm font-semibold text-gray-600">No loans yet</p>
        <p class="mt-1 text-xs text-gray-400">Add the first loan for this customer.</p>
        <%= link_to "Add Loan", new_customer_loan_path(@customer),
            class: "mt-4 inline-flex items-center rounded-lg bg-blue-600 px-5 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition" %>
      </div>

    <% else %>
      <div class="space-y-3">
        <% loans.each do |loan| %>
          <%
            sc = {
              "active"         => { bg: "bg-blue-100",   text: "text-blue-700",   dot: "bg-blue-500" },
              "overdue"        => { bg: "bg-red-100",    text: "text-red-700",    dot: "bg-red-500" },
              "completed"      => { bg: "bg-green-100",  text: "text-green-700",  dot: "bg-green-500" },
              "completed_late" => { bg: "bg-yellow-100", text: "text-yellow-700", dot: "bg-yellow-500" },
            }[loan.status] || { bg: "bg-gray-100", text: "text-gray-600", dot: "bg-gray-400" }
          %>
          <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm transition hover:shadow-md">
            <div class="flex items-start justify-between gap-4">
              <div class="flex items-center gap-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-900">Loan #<%= loan.id %></p>
                  <p class="text-xs text-gray-400"><%= loan.date_added.strftime("%b %d, %Y") %> · <%= loan.session_type.capitalize %></p>
                </div>
              </div>
              <span class="inline-flex shrink-0 items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-semibold <%= sc[:bg] %> <%= sc[:text] %>">
                <span class="h-1.5 w-1.5 rounded-full <%= sc[:dot] %>"></span>
                <%= loan.display_status %>
              </span>
            </div>

            <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
              <div>
                <p class="text-[11px] uppercase tracking-wide text-gray-400">Loan Amount</p>
                <p class="mt-0.5 font-semibold text-gray-800">₱<%= number_with_precision(loan.loan_amount, precision: 2, delimiter: ",") %></p>
              </div>
              <div>
                <p class="text-[11px] uppercase tracking-wide text-gray-400">Total Balance</p>
                <p class="mt-0.5 font-semibold text-gray-800">₱<%= number_with_precision(loan.total_balance, precision: 2, delimiter: ",") %></p>
              </div>
              <div>
                <p class="text-[11px] uppercase tracking-wide text-gray-400">Remaining</p>
                <p class="mt-0.5 font-semibold <%= loan.remaining_balance.to_f <= 0 ? 'text-green-600' : 'text-gray-800' %>">
                  ₱<%= number_with_precision(loan.remaining_balance, precision: 2, delimiter: ",") %>
                </p>
              </div>
              <div>
                <p class="text-[11px] uppercase tracking-wide text-gray-400">Maturity Date</p>
                <p class="mt-0.5 font-semibold <%= loan.overdue? ? 'text-red-600' : 'text-gray-800' %>">
                  <%= loan.maturity_date&.strftime("%b %d, %Y") || "—" %>
                </p>
              </div>
            </div>

            <div class="mt-4 flex items-center justify-end gap-2 border-t border-gray-50 pt-3">
              <%= link_to "View", loan_path(loan),
                  class: "rounded-lg border border-gray-200 px-3 py-1.5 text-xs font-semibold text-gray-600 hover:bg-gray-50 transition" %>
              <%= link_to "Edit", edit_loan_path(loan),
                  class: "rounded-lg border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-semibold text-blue-700 hover:bg-blue-100 transition" %>
            </div>
          </div>
        <% end %>

        <%# View all link if more than 3 %>
        <% if loans.size > 3 %>
          <div class="text-center pt-2">
            <%= link_to "View all #{loans.size} loans →", customer_loans_path(@customer),
                class: "text-sm font-semibold text-blue-600 hover:text-blue-700 transition" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
